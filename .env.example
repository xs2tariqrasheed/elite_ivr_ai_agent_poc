# Copy to .env and fill in your keys.
ASSEMBLYAI_API_KEY=your_assemblyai_key
OPENAI_API_KEY=your_openai_key
ELEVENLABS_API_KEY=your_elevenlabs_key

# Optional overrides
# Speech-to-text backend: "assemblyai" (default) or "deepgram". Set the matching
# API key below for whichever provider you select.
STT_PROVIDER=assemblyai
DEEPGRAM_API_KEY=your_deepgram_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
OPENAI_MODEL=gpt-4o-mini
# Which agent to run (see backend/agents/registry.py)
AGENT=order

# Twilio (phone). Point your number's voice webhook at POST /twilio/voice.
# TWILIO_STREAM_WS_URL is the public wss:// address Twilio dials for the media
# stream; it must resolve to the /twilio/stream endpoint of this server.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_STREAM_WS_URL=

# Supabase Postgres. DIRECT_URL (session-mode pooler, port 5432) is used by the
# app; DATABASE_URL (transaction pooler, port 6543) and DATABASE_PASSWORD are
# kept for reference / migrations.
DATABASE_PASSWORD=your_db_password
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Admin frontend (/admin). PASSCODE gates entry; SESSION_SECRET signs the login
# cookie — set a long random value in production.
PASSCODE=changeme
SESSION_SECRET=change-me-to-a-long-random-string